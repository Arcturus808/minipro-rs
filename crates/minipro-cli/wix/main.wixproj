<Project Sdk="WixToolset.Sdk/7.0.0">
  <PropertyGroup>
    <!-- Accepts the WiX v7 open-source maintenance fee license -->
    <AcceptEula>wix7</AcceptEula>
    <Platform>x64</Platform>
    <Platforms>x64</Platforms>
    <!-- Forward the MSBuild ProductVersion property to the WiX preprocessor -->
    <DefineConstants>ProductVersion=$(ProductVersion)</DefineConstants>
  </PropertyGroup>
</Project>
