<?xml version='1.0' encoding='windows-1252'?>
<!--
  WiX Toolset v3 source for the minipro Windows MSI installer.
  Build with: wixl -D ProductVersion=X.Y.Z -a x64 -o minipro.msi main.wxs
  Paths are relative to this file's directory (crates/minipro-cli/wix/).
-->
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
  <Product
    Id='*'
    Name='minipro'
    UpgradeCode='5C6D2F1A-3B4E-4F2A-8C9D-1A2B3C4D5E6F'
    Manufacturer='minipro-rs contributors'
    Language='1033'
    Codepage='1252'
    Version='$(var.ProductVersion)'>

    <Package
      Id='*'
      Keywords='Installer'
      Description='minipro - XGecu chip programmer utility'
      Manufacturer='minipro-rs contributors'
      InstallerVersion='450'
      Languages='1033'
      Compressed='yes'
      InstallScope='perMachine'
      SummaryCodepage='1252'/>

    <MajorUpgrade
      Schedule='afterInstallInitialize'
      DowngradeErrorMessage='A newer version of minipro is already installed. Setup will now exit.'/>

    <Media Id='1' Cabinet='minipro.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
    <Property Id='DiskPrompt' Value='minipro Installation'/>

    <Directory Id='TARGETDIR' Name='SourceDir'>
      <Directory Id='ProgramFiles64Folder' Name='PFiles'>
        <Directory Id='APPLICATIONFOLDER' Name='minipro'>

          <Component Id='License' Guid='*'>
            <File Id='LicenseFile'
              Name='LICENSE'
              Source='../../../LICENSE'
              KeyPath='yes'/>
          </Component>

          <Directory Id='Bin' Name='bin'>
            <Component Id='Binary' Guid='*'>
              <File Id='minipro.exe'
                Name='minipro.exe'
                Source='../../../target/x86_64-pc-windows-gnu/release/minipro.exe'
                KeyPath='yes'/>
              <Environment
                Id='PATH'
                Name='PATH'
                Value='[Bin]'
                Permanent='no'
                Part='last'
                Action='set'
                System='yes'/>
            </Component>
          </Directory>

        </Directory>
      </Directory>
    </Directory>

    <Feature
      Id='DefaultFeature'
      Title='minipro'
      Description='The complete minipro package'
      Display='expand'
      Level='1'
      ConfigurableDirectory='APPLICATIONFOLDER'>

      <ComponentRef Id='License'/>
      <ComponentRef Id='Binary'/>
    </Feature>

    <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>
    <Icon Id='ProductICO' SourceFile='product.ico'/>
    <Property Id='ARPPRODUCTICON' Value='ProductICO'/>

  </Product>
</Wix>
